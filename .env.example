# Dota 2 Tracker — переменные окружения
# В собранном приложении задаются через Настройки (Alt+S)

# Steam Web API — нужен для получения данных об игроках ВО ВРЕМЯ матча (пик/игра)
# Получи бесплатно: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Anthropic (опционально, для AI-анализа) — https://console.anthropic.com
ANTHROPIC_API_KEY=
